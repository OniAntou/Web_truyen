# Runtime
NODE_ENV=development
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
TRUST_PROXY=1

# URLs (comma-separated origins, without a trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
CLIENT_URL=http://localhost:5173

# MongoDB. Production must use a MongoDB Atlas replica set because wallet unlocks use transactions.
MONGO_URI=mongodb://localhost:27017/skycomic

# Scheduled endpoint authentication
CRON_SECRET=replace_with_a_long_random_secret

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=web-truyen-uploads
R2_PUBLIC_URL=

# Upstash Redis (optional; local in-memory cache is used when omitted)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# VNPay
VNP_TMN_CODE=your_tmn_code
VNP_HASH_SECRET=your_secret_key
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5173/payment/vnpay_return

# SMTP password-reset email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=ComicVerse <noreply@example.com>

# In production every variable above except the two UPSTASH values is required.
# Keep this file as a template only; never commit real credentials.
