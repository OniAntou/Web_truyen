# Server
PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# MongoDB (optional if Database uses its own)
# MONGO_URI=mongodb://localhost:27017/skycomic

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=web-truyen-uploads
R2_PUBLIC_URL=
# VNPay
VNP_TMN_CODE=your_tmn_code
VNP_HASH_SECRET=your_secret_key
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5173/payment/vnpay_return
VNP_IPN_URL=http://localhost:5000/api/payment/vnpay_ipn
# Nếu bucket public, điền URL gốc (vd: https://pub-xxx.r2.dev). Để trống thì dùng signed URL.
# Lưu ý: Tạo bucket (vd: web-truyen-uploads) trong Cloudflare R2 Dashboard trước khi upload.
